{
  "schemaVersion": 1,
  "name": "dart-fixture",
  "version": "1.0.0",
  "language": "Dart/Flutter",
  "detect": {
    "extensions": [".dart"],
    "markers": ["pubspec.yaml"]
  },
  "commands": {
    "test": {
      "granularity": "file",
      "run": "flutter test {file}",
      "passOn": "exitZero"
    },
    "lint": "flutter analyze",
    "format": "dart format"
  },
  "testFilePattern": "*_test.dart",
  "versionFiles": ["pubspec.yaml"],
  "standards": {
    "index": "SKILL.md",
    "dir": "standards/"
  }
}
