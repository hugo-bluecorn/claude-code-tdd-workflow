# bashunit configuration (sourced from the repo root by ./lib/bashunit).
# Keep this valid bash: KEY=value, no spaces around '='.

# Enforce the quality floor: zero-assertion ("risky") tests FAIL the suite
# (bashunit 0.34.1+ detects them; 0.35.0+ can fail on them). Floor = 0 failed
# AND 0 risky.
BASHUNIT_FAIL_ON_RISKY=true

# NOTE: parallel is intentionally NOT enabled globally here. The FULL suite has
# network tests that share set_up_before_script state and race under parallel.
# Per-slice verification gets parallelism via scripts/run-fast-tests.sh (which
# excludes those files). To run the full suite in parallel you must first
# refactor test/integration/external_conventions_repo_test.sh off its shared
# $CLONE_DIR global. See memory: bashunit-036-capabilities.
